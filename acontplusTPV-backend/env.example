# =============================================================================
# .env.example — acontplusTPV Stack
#
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Completar TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA commitear el .env real al repositorio
#   4. En el VPS, gestionar este archivo con permisos 600:
#      chmod 600 .env
#
# GENERACIÓN DE SECRETOS:
#   Para cualquier SECRET o PASSWORD, generar con:
#     openssl rand -base64 48
#   O para hex:
#     openssl rand -hex 32
# =============================================================================


# =============================================================================
# POSTGRESQL
# =============================================================================

# Base de datos principal
POSTGRES_DB=acontplusTPV

# Usuario principal de la aplicación (sujeto a RLS)
# Corresponde a 'acontplus_app' en la documentación de prisma.ts
POSTGRES_USER=acontplus_app
POSTGRES_PASSWORD=<CAMBIAR_password_seguro_min_32_chars>

# Usuario de autenticación (BYPASSRLS — solo para DeviceToken/Device/User)
# Ver lib/prisma.ts para la configuración de este usuario
# Crear manualmente en PostgreSQL tras el primer deploy:
#   CREATE ROLE acontplus_auth LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE "acontplusTPV" TO acontplus_auth;
#   GRANT USAGE ON SCHEMA public TO acontplus_auth;
#   GRANT SELECT ON "DeviceToken", "Device", "User" TO acontplus_auth;
#   GRANT UPDATE ("lastUsedAt") ON "DeviceToken" TO acontplus_auth;
#   ALTER ROLE acontplus_auth BYPASSRLS;
POSTGRES_AUTH_USER=acontplus_auth
POSTGRES_AUTH_PASSWORD=<CAMBIAR_password_diferente_al_principal>

# Las DATABASE_URL se construyen automáticamente en docker-compose.yml
# usando los valores anteriores — no modificar estas líneas si usas Docker.
# Para desarrollo local sin Docker, descomentar y ajustar:
# DATABASE_URL=postgresql://acontplus_app:<PASSWORD>@localhost:5432/acontplusTPV
# DATABASE_URL_AUTH=postgresql://acontplus_auth:<PASSWORD>@localhost:5432/acontplusTPV


# =============================================================================
# REDIS
# =============================================================================

# Contraseña de Redis para BullMQ
# La URL se construye automáticamente en docker-compose.yml
REDIS_PASSWORD=<CAMBIAR_redis_password_min_32_chars>

# Para desarrollo local sin Docker:
# REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379


# =============================================================================
# JWT — Tokens de autenticación
# =============================================================================

# Secreto para firmar accessToken y refreshToken de usuarios
# (WAITER_DEVICE, ADMIN_DEVICE)
# CRÍTICO: debe ser diferente al de PowerSync
JWT_SECRET=<CAMBIAR_openssl_rand_base64_48>

# Secreto separado para refreshTokens — permite invalidarlos independientemente
JWT_REFRESH_SECRET=<CAMBIAR_openssl_rand_base64_48>

# Secreto compartido entre el backend y PowerSync Service
# El backend lo usa para firmar el PowerSync JWT (/auth/powersync-token)
# PowerSync lo usa para validar ese JWT antes de sincronizar
# CRÍTICO: debe coincidir exactamente entre api y powersync services
POWERSYNC_JWT_SECRET=<CAMBIAR_openssl_rand_base64_48>


# =============================================================================
# API FASTIFY
# =============================================================================

# Puerto interno del servidor (dentro del contenedor)
# El tráfico externo llega por nginx en 80/443 y se proxea aquí
API_PORT=3000
API_HOST=0.0.0.0

# Orígenes CORS permitidos (separados por coma, sin espacios)
# Incluir la URL del panel admin Next.js y cualquier cliente web
CORS_ORIGINS=https://admin.tudominio.com,https://tudominio.com

# URL pública de la API (usada por PowerSync para callback de autenticación)
# Debe ser la URL HTTPS pública, sin trailing slash
API_PUBLIC_URL=https://api.tudominio.com


# =============================================================================
# POWERSYNC
# =============================================================================

# URL pública del servicio PowerSync (para que los clientes móviles conecten)
# Debe ser la URL HTTPS pública del servicio PowerSync
POWERSYNC_URL=https://powersync.tudominio.com

# Puerto interno de PowerSync (dentro del contenedor)
# nginx proxea el tráfico externo a este puerto
POWERSYNC_PORT=8080


# =============================================================================
# NGINX
# =============================================================================

# Nombre del servidor (usado en los virtual hosts de nginx)
# Debe coincidir con los subdominios configurados en DNS
NGINX_API_DOMAIN=api.tudominio.com
NGINX_POWERSYNC_DOMAIN=powersync.tudominio.com
NGINX_ADMIN_DOMAIN=admin.tudominio.com

# Email para Let's Encrypt (certificados TLS automáticos)
LETSENCRYPT_EMAIL=admin@tudominio.com


# =============================================================================
# NODE / ENTORNO
# =============================================================================

NODE_ENV=production

# Zona horaria del servidor (debe coincidir con la del negocio)
# Ver lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Guayaquil


# =============================================================================
# BULLMQ (Fase futura — resolución de conflictos offline)
# =============================================================================

# Número máximo de workers de BullMQ (uno por tipo de conflicto)
# Ajustar según la carga del negocio
# BULLMQ_CONCURRENCY=5

# Tiempo de retención de jobs completados (en ms) — por defecto 24h
# BULLMQ_JOB_TTL=86400000


# =============================================================================
# MONITORING (Opcional — Fase futura)
# =============================================================================

# Sentry DSN para captura de errores en producción
# SENTRY_DSN=https://...@sentry.io/...

# Uptime monitoring (UptimeRobot, Better Uptime, etc.)
# HEALTH_CHECK_SECRET=<token_para_endpoint_health_autenticado>
