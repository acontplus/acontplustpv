// =============================================================================
// ACONTPLUS SaaS — schema.prisma v2.2
// SaaS Multi-tenant · POS + Mini-ERP · Offline-First
// Basado en: ACONTPLUS_SaaS_Master_Instructions_v2_1.md
// v2.2: Establecimientos + Puntos de Emisión + Numeración tributaria
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum TenantPlan {
  TRIAL
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum BusinessType {
  BAR
  RESTAURANT
  HELADERIA
  CAFETERIA
  FOOD_TRUCK
  OTHER
}

enum Role {
  ADMIN
  CASHIER
  BARMAN
  WAITER
}

enum DeviceRole {
  WAITER_DEVICE
  PRINT_NODE
  ADMIN_DEVICE
  KIOSK_DEVICE
}

enum SalaryType {
  FIXED
  PER_DAY
  PER_SHIFT
}

enum PayPeriod {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum LedgerEntryType {
  ADVANCE_RECEIVED
  CREDIT_CONSUMPTION
  CREDIT_PAYMENT
  COMMISSION_EARNED
  SALARY_PAYMENT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_EMPLOYEE
  CREDIT_CUSTOMER
  MIXED
}

enum WarehouseType {
  MAIN_STORAGE
  BAR
  SECONDARY
}

enum ProductUnit {
  UNIT
  KG
  LITER
  ML
  GRAM
}

enum MovementType {
  INITIAL_STOCK
  PURCHASE_RECEIPT
  INTERNAL_TRANSFER
  SALE_DEDUCTION
  WASTE_ADJUSTMENT
  AUDIT_ADJUSTMENT
  RETURN_TO_SUPPLIER
}

enum PurchaseOrderStatus {
  PENDING
  PARTIAL
  RECEIVED
  CANCELLED
}

enum AuditStatus {
  IN_PROGRESS
  COMPLETED
  APPROVED
}

enum OrderStatus {
  DRAFT
  KIOSK_PENDING
  CONFIRMED
  SERVED
  AWAITING_PAYMENT
  AWAITING_PAYMENT_AT_CASHIER
  CREDIT_REQUESTED
  PAID_CASH
  PAID_TRANSFER_PENDING
  PAID_TRANSFER_CONFIRMED
  PAID_CREDIT
  CANCELLED
  EXPIRED
}

enum PrintStatus {
  PENDING
  PRINTING
  PRINTED
  FAILED
  SKIPPED
}

enum CancellationReason {
  CUSTOMER_LEFT
  CUSTOMER_REQUEST
  ITEM_UNAVAILABLE
  PAYMENT_FAILED
  OPERATOR_ERROR
  SYSTEM_ERROR
  OTHER
}

enum TransferStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum CashEventType {
  SHIFT_OPEN
  SALE_CASH
  SALE_TRANSFER
  TRANSFER_CONFIRMED
  TRANSFER_REJECTED
  BLIND_COUNT
  SHIFT_CLOSE
  ADJUSTMENT
  CREDIT_PAYMENT_RECEIVED
  CASH_OUT_ADVANCE
  CASH_OUT_EXPENSE
  CASH_OUT_ADJUSTMENT
}

enum CreditEventType {
  CREDIT_ISSUED
  PAYMENT_RECEIVED
  CREDIT_CANCELLED
  DISCOUNT_APPLIED
}

// =============================================================================
// MULTI-TENANT
// =============================================================================

model Tenant {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String       @unique
  plan            TenantPlan   @default(TRIAL)
  businessType    BusinessType @default(BAR)
  timezone        String       @default("America/Guayaquil")
  currency        String       @default("USD")
  country         String       @default("EC")
  isActive        Boolean      @default(true)
  maxDevices      Int          @default(5)
  maxUsers        Int          @default(10)
  maxProducts     Int          @default(500)
  suspendedAt     DateTime?
  suspendedReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  establishments      Establishment[]
  pointsOfSale        PointOfSale[]
  users               User[]
  userRoles           UserRole[]
  devices             Device[]
  deviceTokens        DeviceToken[]
  employeeContracts   EmployeeContract[]
  ledgerEntries       EmployeeLedgerEntry[]
  payrollRecords      PayrollRecord[]
  warehouses          Warehouse[]
  productCategories   ProductCategory[]
  products            Product[]
  stockLevels         StockLevel[]
  stockMovements      StockMovement[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  purchaseOrderItems  PurchaseOrderItem[]
  inventoryAudits     InventoryAudit[]
  inventoryAuditItems InventoryAuditItem[]
  businessDays        BusinessDay[]
  tables              Table[]
  orders              Order[]
  orderItems          OrderItem[]
  transferPayments    TransferPayment[]
  cashRegisterEvents  CashRegisterEvent[]
  customers           Customer[]
  creditTransactions  CreditTransaction[]
}

// =============================================================================
// ESTABLECIMIENTOS Y PUNTOS DE EMISIÓN (v2.2)
// =============================================================================

model Establishment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  code      String
  name      String
  address   String?
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  pointsOfSale    PointOfSale[]
  warehouses      Warehouse[]
  businessDays    BusinessDay[]
  devices         Device[]
  tables          Table[]
  orders          Order[]
  stockMovements  StockMovement[]
  purchaseOrders  PurchaseOrder[]
  inventoryAudits InventoryAudit[]
  cashRegisterEvents  CashRegisterEvent[]
  transferPayments    TransferPayment[]
  ledgerEntries       EmployeeLedgerEntry[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model PointOfSale {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  establishmentId String    @db.Uuid
  code            String
  name            String
  lastSequential  Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  devices       Device[]
  orders        Order[]

  @@unique([establishmentId, code])
  @@index([tenantId, establishmentId, isActive])
}

// =============================================================================
// USUARIOS Y DISPOSITIVOS
// =============================================================================

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  name             String
  pinHash          String
  isActive         Boolean   @default(true)
  deactivatedAt    DateTime?
  deactivatedBy    String?   @db.Uuid
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  roles                  UserRole[]
  contracts              EmployeeContract[]   @relation("ContractEmployee")
  createdContracts       EmployeeContract[]   @relation("ContractCreatedBy")
  ledgerEntries          EmployeeLedgerEntry[] @relation("LedgerEmployee")
  authorizedLedger       EmployeeLedgerEntry[] @relation("LedgerAuthorizer")
  payrollRecords         PayrollRecord[]       @relation("PayrollEmployee")
  paidPayrolls           PayrollRecord[]       @relation("PayrollPaidBy")
  ordersCreated          Order[]               @relation("OrderCreatedByUser")
  ordersClosed           Order[]               @relation("OrderClosedBy")
  ordersCancelled        Order[]               @relation("OrderCancelledBy")
  cashEvents             CashRegisterEvent[]
  authorizedCredits      CreditTransaction[]   @relation("CreditAuthorizedBy")
  debtorCredits          CreditTransaction[]   @relation("CreditDebtorUser")
  capturedTransfers      TransferPayment[]     @relation("TransferCapturedBy")
  reviewedTransfers      TransferPayment[]     @relation("TransferReviewedBy")
  conductedAudits        InventoryAudit[]
  createdPurchaseOrders  PurchaseOrder[]       @relation("PurchaseCreatedBy")
  receivedPurchaseOrders PurchaseOrder[]       @relation("PurchaseReceivedBy")
  openedDays             BusinessDay[]         @relation("DayOpenedBy")
  closedDays             BusinessDay[]         @relation("DayClosedBy")
  stockMovementsCreated  StockMovement[]

  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
}

// SIN updatedAt — append-only (Instrucciones §4)
model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  role      Role
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, role])
  @@index([tenantId, userId])
  @@index([tenantId, role])
}

model Device {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String     @db.Uuid
  establishmentId String     @db.Uuid
  pointOfSaleId   String     @db.Uuid
  name            String
  role            DeviceRole
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  pointOfSale   PointOfSale   @relation(fields: [pointOfSaleId], references: [id], onDelete: Cascade)

  tokens             DeviceToken[]
  ordersCreated      Order[]           @relation("OrderCreatedByDevice")
  printedOrders      Order[]           @relation("OrderPrintedByDevice")
  capturedTransfers  TransferPayment[] @relation("TransferCapturedByDevice")
  stockMovements     StockMovement[]
  ledgerEntries      EmployeeLedgerEntry[]
  creditTransactions CreditTransaction[]

  @@index([tenantId, establishmentId, role, isActive])
  @@index([tenantId, pointOfSaleId])
  @@index([tenantId, deletedAt])
}

// SIN updatedAt — registro inmutable (Instrucciones §4)
model DeviceToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  deviceId   String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId])
  @@index([tokenHash])
}

// =============================================================================
// CONTRATOS Y NÓMINA (ERP)
// =============================================================================

model EmployeeContract {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String     @db.Uuid
  userId         String     @db.Uuid
  salaryType     SalaryType
  payPeriod      PayPeriod
  baseAmount     Decimal    @db.Decimal(10, 2)
  commissionRate Decimal    @default(0) @db.Decimal(5, 4)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdBy      String     @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User     @relation("ContractEmployee", fields: [userId], references: [id], onDelete: Restrict)
  createdByUser User     @relation("ContractCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  payrollRecords PayrollRecord[]

  @@index([tenantId, userId, effectiveTo])
}

// SIN updatedAt — append-only (Instrucciones §4, §5)
// cashRegisterEventId: referencia cruzada para anticipos (Instrucciones §5)
model EmployeeLedgerEntry {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String          @db.Uuid
  establishmentId     String          @db.Uuid
  userId              String          @db.Uuid
  type                LedgerEntryType
  amount              Decimal         @db.Decimal(10, 2)
  businessDayId       String          @db.Uuid
  // Cross-reference: cuando type=ADVANCE_RECEIVED, apunta al CashRegisterEvent correspondiente
  cashRegisterEventId String?         @db.Uuid
  creditTransactionId String?         @db.Uuid
  orderId             String?         @db.Uuid
  authorizedBy        String          @db.Uuid
  notes               String?
  deviceId            String          @db.Uuid
  createdAt           DateTime        @default(now())
  // SIN updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment     Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  user              User               @relation("LedgerEmployee", fields: [userId], references: [id], onDelete: Restrict)
  authorizer        User               @relation("LedgerAuthorizer", fields: [authorizedBy], references: [id], onDelete: Restrict)
  businessDay       BusinessDay        @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  device            Device             @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  // cashRegisterEventId is a plain cross-reference field (no Prisma relation defined here
  // to avoid circular FK conflict). Query directly: WHERE cash_register_event_id = X
  creditTransaction CreditTransaction? @relation(fields: [creditTransactionId], references: [id], onDelete: SetNull)
  payrollRecord     PayrollRecord?     @relation("LedgerForPayroll")

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, establishmentId, businessDayId])
}

// SIN updatedAt — snapshot inmutable (Instrucciones §5)
model PayrollRecord {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String        @db.Uuid
  userId                String        @db.Uuid
  contractSnapshotId    String        @db.Uuid
  periodStart           DateTime
  periodEnd             DateTime
  workedDaysOrShifts    Int?
  baseSalary            Decimal       @db.Decimal(10, 2)
  commissionableAmount  Decimal       @db.Decimal(10, 2)
  commissionRate        Decimal       @db.Decimal(5, 4)
  commissionsEarned     Decimal       @db.Decimal(10, 2)
  advancesDeducted      Decimal       @db.Decimal(10, 2)
  creditConsumptions    Decimal       @db.Decimal(10, 2)
  netPayment            Decimal       @db.Decimal(10, 2)
  paymentMethod         PaymentMethod
  receiptUrl            String?
  hasPendingAdjustments Boolean       @default(false)
  paidBy                String        @db.Uuid
  paidAt                DateTime      @default(now())
  notes                 String?
  ledgerEntryId         String        @unique @db.Uuid
  createdAt             DateTime      @default(now())
  // SIN updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user        User                @relation("PayrollEmployee", fields: [userId], references: [id], onDelete: Restrict)
  paidByUser  User                @relation("PayrollPaidBy", fields: [paidBy], references: [id], onDelete: Restrict)
  contract    EmployeeContract    @relation(fields: [contractSnapshotId], references: [id], onDelete: Restrict)
  ledgerEntry EmployeeLedgerEntry @relation("LedgerForPayroll", fields: [ledgerEntryId], references: [id], onDelete: Restrict)

  @@index([tenantId, userId, periodStart])
  @@index([tenantId, paidAt])
}

// =============================================================================
// INVENTARIO MULTI-BODEGA
// =============================================================================

model Warehouse {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @db.Uuid
  establishmentId String        @db.Uuid
  name            String
  type            WarehouseType
  isDefault       Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment   Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  stockLevels     StockLevel[]
  inboundMoves    StockMovement[] @relation("MovementDest")
  outboundMoves   StockMovement[] @relation("MovementSource")
  purchaseOrders  PurchaseOrder[]
  inventoryAudits InventoryAudit[]

  @@unique([establishmentId, name])
  @@index([tenantId, establishmentId, isDefault, isActive])
}

model ProductCategory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  name         String
  description  String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId, displayOrder, isActive])
}

model Product {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String      @db.Uuid
  categoryId         String      @db.Uuid
  name               String
  description        String?
  salePrice          Decimal     @db.Decimal(10, 2)
  currentAverageCost Decimal     @default(0) @db.Decimal(10, 2)
  reorderPoint       Decimal     @default(0) @db.Decimal(10, 3)
  unit               ProductUnit @default(UNIT)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category           ProductCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stockLevels        StockLevel[]
  stockMovements     StockMovement[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  auditItems         InventoryAuditItem[]

  @@index([tenantId, categoryId, isActive])
  @@index([tenantId, isActive])
}

model StockLevel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  warehouseId String   @db.Uuid
  productId   String   @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(10, 3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([warehouseId, productId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
}

// SIN updatedAt — append-only (Instrucciones §4, §6)
model StockMovement {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String       @db.Uuid
  establishmentId   String       @db.Uuid
  type              MovementType
  sourceWarehouseId String?      @db.Uuid
  destWarehouseId   String?      @db.Uuid
  productId         String       @db.Uuid
  quantity          Decimal      @db.Decimal(10, 3)
  unitCost          Decimal?     @db.Decimal(10, 2)
  orderId           String?      @db.Uuid
  purchaseOrderId   String?      @db.Uuid
  auditId           String?      @db.Uuid
  businessDayId     String?      @db.Uuid
  createdBy         String       @db.Uuid
  deviceId          String       @db.Uuid
  notes             String?
  createdAt         DateTime     @default(now())
  // SIN updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment   Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourceWarehouse Warehouse?      @relation("MovementSource", fields: [sourceWarehouseId], references: [id], onDelete: Restrict)
  destWarehouse   Warehouse?      @relation("MovementDest", fields: [destWarehouseId], references: [id], onDelete: Restrict)
  order           Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  audit           InventoryAudit? @relation(fields: [auditId], references: [id], onDelete: SetNull)
  businessDay     BusinessDay?    @relation(fields: [businessDayId], references: [id], onDelete: SetNull)
  createdByUser   User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  device          Device          @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  @@index([tenantId, establishmentId, productId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, orderId])
  @@index([tenantId, businessDayId])
}

model Supplier {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model PurchaseOrder {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String              @db.Uuid
  establishmentId String              @db.Uuid
  supplierId      String              @db.Uuid
  warehouseId     String              @db.Uuid
  businessDayId   String?             @db.Uuid
  status          PurchaseOrderStatus @default(PENDING)
  orderDate       DateTime            @default(now())
  receivedAt      DateTime?
  totalAmount     Decimal?            @db.Decimal(10, 2)
  createdBy       String              @db.Uuid
  receivedBy      String?             @db.Uuid
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment  Establishment       @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  businessDay    BusinessDay?        @relation(fields: [businessDayId], references: [id], onDelete: SetNull)
  createdByUser  User                @relation("PurchaseCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  receivedByUser User?               @relation("PurchaseReceivedBy", fields: [receivedBy], references: [id], onDelete: SetNull)
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([tenantId, establishmentId, supplierId, status])
  @@index([tenantId, businessDayId])
}

model PurchaseOrderItem {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String        @db.Uuid
  purchaseOrderId  String        @db.Uuid
  productId        String        @db.Uuid
  quantityOrdered  Decimal       @db.Decimal(10, 3)
  quantityReceived Decimal       @default(0) @db.Decimal(10, 3)
  unitCost         Decimal       @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId, purchaseOrderId])
}

model InventoryAudit {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @db.Uuid
  establishmentId String      @db.Uuid
  warehouseId     String      @db.Uuid
  businessDayId   String      @db.Uuid
  status          AuditStatus @default(IN_PROGRESS)
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  conductedBy     String      @db.Uuid
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment  Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  warehouse      Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  businessDay    BusinessDay        @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  conductor      User               @relation(fields: [conductedBy], references: [id], onDelete: Restrict)
  items          InventoryAuditItem[]
  stockMovements StockMovement[]

  @@index([tenantId, establishmentId, warehouseId, status])
  @@index([tenantId, businessDayId])
}

// SIN updatedAt — snapshot inmutable (Instrucciones §4)
model InventoryAuditItem {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String         @db.Uuid
  auditId          String         @db.Uuid
  productId        String         @db.Uuid
  theoreticalStock Decimal        @db.Decimal(10, 3)
  physicalStock    Decimal?       @db.Decimal(10, 3)
  variance         Decimal?       @db.Decimal(10, 3)
  notes            String?
  createdAt        DateTime       @default(now())
  // SIN updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  audit   InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([auditId, productId])
  @@index([tenantId, auditId])
}

// =============================================================================
// OPERACIÓN DEL BAR
// =============================================================================

// Bloqueo por establecimiento (v2.2)
// Partial unique index SQL: (tenant_id, establishment_id) WHERE is_open = true
model BusinessDay {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  establishmentId String    @db.Uuid
  isOpen          Boolean   @default(true)
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  openedBy        String    @db.Uuid
  closedBy        String?   @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  openedByUser  User          @relation("DayOpenedBy", fields: [openedBy], references: [id], onDelete: Restrict)
  closedByUser  User?         @relation("DayClosedBy", fields: [closedBy], references: [id], onDelete: SetNull)

  orders             Order[]
  cashEvents         CashRegisterEvent[]
  creditTransactions CreditTransaction[]
  ledgerEntries      EmployeeLedgerEntry[]
  stockMovements     StockMovement[]
  purchaseOrders     PurchaseOrder[]
  inventoryAudits    InventoryAudit[]
  transferPayments   TransferPayment[]

  @@index([tenantId, establishmentId, isOpen])
  @@index([tenantId, establishmentId, openedAt])
}

model Table {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  establishmentId String    @db.Uuid
  number          Int
  alias           String?
  capacity        Int?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@unique([establishmentId, number])
  @@index([tenantId, establishmentId, isActive])
}

model Order {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  establishmentId String    @db.Uuid
  pointOfSaleId   String    @db.Uuid
  businessDayId   String    @db.Uuid

  // Numeración tributaria (v2.2)
  orderNumber   String?
  localSequence String

  // Autoría polimórfica — constraint SQL: al menos uno presente siempre
  createdByUserId   String? @db.Uuid
  createdByDeviceId String? @db.Uuid
  closedByUserId    String? @db.Uuid

  // Ubicación
  tableId         String?  @db.Uuid
  tableAlias      String?
  kioskTurnNumber String?

  status        OrderStatus    @default(DRAFT)
  paymentMethod PaymentMethod?

  // Impresión — lock distribuido (Instrucciones §3)
  printStatus       PrintStatus @default(PENDING)
  printedByDeviceId String?     @db.Uuid
  printedAt         DateTime?

  // Cancelación
  cancellationReason CancellationReason?
  cancellationNotes  String?
  cancelledBy        String?   @db.Uuid
  cancelledAt        DateTime?

  subtotal    Decimal @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @default(0) @db.Decimal(10, 2)

  notes     String?
  deviceId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  pointOfSale     PointOfSale   @relation(fields: [pointOfSaleId], references: [id], onDelete: Restrict)
  businessDay     BusinessDay   @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  createdByUser   User?         @relation("OrderCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdByDevice Device?       @relation("OrderCreatedByDevice", fields: [createdByDeviceId], references: [id], onDelete: SetNull)
  closedByUser    User?         @relation("OrderClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  cancelledByUser User?         @relation("OrderCancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  printedByDevice Device?       @relation("OrderPrintedByDevice", fields: [printedByDeviceId], references: [id], onDelete: SetNull)
  table           Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)

  items              OrderItem[]
  transferPayments   TransferPayment[]
  stockMovements     StockMovement[]
  creditTransactions CreditTransaction[]
  cashEvents         CashRegisterEvent[]

  @@index([tenantId, establishmentId, businessDayId, status])
  @@index([tenantId, establishmentId, pointOfSaleId, status])
  @@index([tenantId, createdByUserId, status])
  @@index([tenantId, printStatus, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, orderNumber])
  @@index([tenantId, localSequence])
}

model OrderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
  unitCost  Decimal? @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId, orderId])
  @@index([tenantId, productId])
}

// =============================================================================
// PAGOS Y FINANZAS
// =============================================================================

model TransferPayment {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String         @db.Uuid
  establishmentId    String         @db.Uuid
  orderId            String         @db.Uuid
  businessDayId      String         @db.Uuid
  amount             Decimal        @db.Decimal(10, 2)
  bankName           String
  referenceNumber    String
  receiptUrl         String?
  targetAccount      String
  status             TransferStatus @default(PENDING)
  capturedByUserId   String         @db.Uuid
  capturedByDeviceId String         @db.Uuid
  capturedAt         DateTime
  reviewedByUserId   String?        @db.Uuid
  reviewedAt         DateTime?
  reviewNotes        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  businessDay      BusinessDay   @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  capturedByUser   User          @relation("TransferCapturedBy", fields: [capturedByUserId], references: [id], onDelete: Restrict)
  capturedByDevice Device        @relation("TransferCapturedByDevice", fields: [capturedByDeviceId], references: [id], onDelete: Restrict)
  reviewedByUser   User?         @relation("TransferReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  cashEvents       CashRegisterEvent[]

  @@index([tenantId, establishmentId, status, capturedAt])
  @@index([tenantId, businessDayId, status])
  @@index([tenantId, targetAccount, status])
}

// SIN updatedAt — append-only (Instrucciones §4)
// employeeLedgerEntryId: cross-reference para CASH_OUT_ADVANCE (Instrucciones §5)
// Este campo se mantiene como UUID plano sin @relation de Prisma para evitar
// la FK circular con EmployeeLedgerEntry. Se consulta directamente en SQL.
model CashRegisterEvent {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String        @db.Uuid
  establishmentId       String        @db.Uuid
  businessDayId         String        @db.Uuid
  type                  CashEventType
  amount                Decimal       @db.Decimal(10, 2)
  userId                String        @db.Uuid
  orderId               String?       @db.Uuid
  transferPaymentId     String?       @db.Uuid
  // Cross-reference sin @relation — evita FK circular con EmployeeLedgerEntry
  // Usar para anticipo: INSERT en ambas tablas con referencia cruzada
  employeeLedgerEntryId String?       @db.Uuid
  deviceId              String        @db.Uuid
  notes                 String?
  createdAt             DateTime      @default(now())
  // SIN updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  establishment   Establishment    @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  businessDay     BusinessDay      @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  transferPayment TransferPayment? @relation(fields: [transferPaymentId], references: [id], onDelete: SetNull)

  @@index([tenantId, establishmentId, businessDayId, type])
  @@index([tenantId, establishmentId, businessDayId, createdAt])
  @@index([tenantId, userId, createdAt])
}

model Customer {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  phone       String?
  creditLimit Decimal   @default(0) @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  credits CreditTransaction[] @relation("CreditDebtorCustomer")

  @@unique([tenantId, phone])
  @@index([tenantId, isActive])
}

// SIN updatedAt — append-only (Instrucciones §4)
// debtorUserId XOR debtorCustomerId — constraint SQL (Instrucciones §4)
model CreditTransaction {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String          @db.Uuid
  businessDayId      String          @db.Uuid
  type               CreditEventType
  amount             Decimal         @db.Decimal(10, 2)
  debtorUserId       String?         @db.Uuid
  debtorCustomerId   String?         @db.Uuid
  orderId            String?         @db.Uuid
  authorizedBy       String          @db.Uuid
  appliedToPayrollId String?         @db.Uuid
  appliedAmount      Decimal?        @db.Decimal(10, 2)
  originalCreditId   String?         @db.Uuid
  deviceId           String          @db.Uuid
  notes              String?
  createdAt          DateTime        @default(now())
  // SIN updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  businessDay    BusinessDay         @relation(fields: [businessDayId], references: [id], onDelete: Restrict)
  debtorUser     User?               @relation("CreditDebtorUser", fields: [debtorUserId], references: [id], onDelete: Restrict)
  debtorCustomer Customer?           @relation("CreditDebtorCustomer", fields: [debtorCustomerId], references: [id], onDelete: Restrict)
  order          Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  authorizer     User                @relation("CreditAuthorizedBy", fields: [authorizedBy], references: [id], onDelete: Restrict)
  device         Device              @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  ledgerEntries  EmployeeLedgerEntry[]
  originalCredit CreditTransaction?  @relation("CreditAbonos", fields: [originalCreditId], references: [id], onDelete: SetNull)
  abonos         CreditTransaction[] @relation("CreditAbonos")

  @@index([tenantId, debtorUserId])
  @@index([tenantId, debtorCustomerId])
  @@index([tenantId, businessDayId, type])
  @@index([tenantId, type, createdAt])
}

